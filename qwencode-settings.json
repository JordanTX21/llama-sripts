{
  "ide": {
    "hasSeenNudge": true
  },
  "env": {
    "LLAMA_CPP_API_KEY": "llama.cpp"
  },
  "modelProviders": {
    "openai": [
      {
        "id": "llama.cpp",
        "name": "llama.cpp",
        "baseUrl": "http://127.0.0.1:8080/v1",
        "envKey": "LLAMA_CPP_API_KEY",
        "generationConfig": {
          "extra_body": {
            "enable_thinking": true
          },
          "modalities": {
            "image": true
          },
          "contextWindowSize": 131072
        }
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "llama.cpp",
    "baseUrl": "http://127.0.0.1:8080/v1"
  },
  "$version": 4,
  "tools": {
    "approvalMode": "yolo"
  },
  "general": {
    "language": "en",
    "outputLanguage": "Español"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp"
    }
  }
}